# Minimal helper image carrying nft, for the pasta egress lock-down init step
# (docs/architecture.md §5.3). It runs once per pasta launch inside the app pod's
# network namespace (with namespaced CAP_NET_ADMIN), loads the ruleset hzc pipes
# in on stdin, and exits — the rules persist in the pod netns for the app that
# starts next, so the app never sees an open network.
#
# trusted-* per §5.5: referenced by a local tag, built from this vetted
# Containerfile whose FROM base is pinned by digest. Unlike the Go-tool build
# (../Containerfile), this one runs `apk add` and so needs network at build time —
# acceptable for a locally built helper, the same way trusted-* images build (§7).
# nft is pinned by version below; folding it into the trusted-* layering is M5.
#
# Build:  cd hzc && make netfilter-image
#         (or: podman build -t hyprzinc/trusted-netfilter:local images/netfilter)
FROM docker.io/library/alpine@sha256:4bcff63911fcb4448bd4fdacec207030997caf25e9bea4045fa6c8c44de311d1

# Pinned to the version in the pinned base's repo (alpine v3.22/main) for
# reproducibility — this image runs with CAP_NET_ADMIN and writes the egress
# ruleset. apk resolves the dep tree, so only the top-level package is pinned.
RUN apk add --no-cache nftables=1.1.3-r0

# No ENTRYPOINT: hzc invokes `nft -f -` explicitly (see runspec.nftApplyArgs).
